# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated merkle proofs
scripts/whitelist-proofs.json
scripts/migration-proofs.json

# claude code superpowers plugin metadata
.superpowers/

# dev/test image artifacts (logo iterations + kitbash test renders)
# canonical logo lives at scripts/gndm-token-logoFINAL.png
scripts/gndm-token-logo-[0-9]*.png
scripts/kitbash-[0-9]*.png
